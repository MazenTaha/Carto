// Prisma schema for Carto Smart Shopping Cart System
// This schema defines the database structure for users, shopping lists, cart sessions, receipts,
// stores, physical carts, wishlists, user analytics, favorites, and notifications.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER ──────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  email       String?  @unique
  password    String?
  name        String?
  phoneNumber String?  @unique
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  shoppingLists    ShoppingList[]
  cartSessions     CartSession[]
  receipts         Receipt[]
  stats            UserStats?
  favoriteProducts UserFavoriteProduct[]
  wishlist         Wishlist?
  notifications    Notification[]

  @@index([phoneNumber])
  @@map("users")
}

model GuestSession {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?

  shoppingLists ShoppingList[]
  cartSessions  CartSession[]
  receipts      Receipt[]

  @@index([expiresAt])
  @@map("guest_sessions")
}

// ─── STORE ─────────────────────────────────────────────────────────────────────

model Store {
  id        String   @id @default(cuid())
  name      String
  location  String?
  currency  String   @default("EGP")
  taxRate   Float    @default(0.085)
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  carts    Cart[]
  receipts Receipt[]

  @@map("stores")
}

// ─── PHYSICAL CART ─────────────────────────────────────────────────────────────

model Cart {
  id            String     @id @default(cuid())
  cartCode      String     @unique // Physical code printed on the cart (scanned via QR)
  bluetoothName String?
  pairingCode   String?
  deviceSecret  String?    @unique
  pairingExpiresAt DateTime?
  qrSessionId   String?
  storeId       String
  status        CartStatus @default(AVAILABLE)
  lastSeen      DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now()) @updatedAt

  store    Store         @relation(fields: [storeId], references: [id])
  sessions CartSession[]

  @@index([storeId])
  @@index([cartCode])
  @@index([pairingExpiresAt])
  @@map("carts")
}

enum CartStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  OFFLINE
}

// ─── SHOPPING LIST ─────────────────────────────────────────────────────────────

model ShoppingList {
  id                String    @id @default(cuid())
  name              String
  userId            String?
  guestSessionId    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  permanentDeleteAt DateTime?

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestSession GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  items        ListItem[]
  cartSessions CartSession[]

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([guestSessionId])
  @@index([guestSessionId, deletedAt])
  @@index([permanentDeleteAt])
  @@map("shopping_lists")
}

// ─── LIST ITEM ─────────────────────────────────────────────────────────────────

model ListItem {
  id          String    @id @default(cuid())
  name        String
  quantity    Int       @default(1)
  price       Float     @default(0)
  category    String?
  isCollected Boolean   @default(false)
  collectedAt DateTime?
  listId      String

  shoppingList ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
  @@map("list_items")
}

// ─── CART SESSION ──────────────────────────────────────────────────────────────

model CartSession {
  id                String        @id @default(cuid())
  cartId            String // References physical Cart
  userId            String?
  guestSessionId    String?
  listId            String
  status            SessionStatus @default(ACTIVE)
  startedAt         DateTime      @default(now())
  endedAt           DateTime?
  qrCode            String?
  externalSessionId String?

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestSession GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  shoppingList ShoppingList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  cart         Cart          @relation(fields: [cartId], references: [id])
  receipt      Receipt?

  @@index([userId])
  @@index([guestSessionId])
  @@index([listId])
  @@index([cartId])
  @@index([externalSessionId])
  @@map("cart_sessions")
}

enum SessionStatus {
  ACTIVE
  DISCONNECTED
  COMPLETED
  CHECKED_OUT
}

// ─── RECEIPT ───────────────────────────────────────────────────────────────────

model Receipt {
  id             String        @id @default(cuid())
  sessionId      String        @unique
  userId         String?
  guestSessionId String?
  status         ReceiptStatus @default(DRAFT)
  subtotal       Float         @default(0)
  tax            Float         @default(0)
  total          Float         @default(0)
  createdAt      DateTime      @default(now())
  lockedAt       DateTime?
  paidAt         DateTime?
  paymentId      String?

  // New fields
  storeId       String?
  cartId        String?
  paymentMethod PaymentMethod @default(CARD)
  paymentStatus PaymentStatus @default(PENDING)

  cartSession     CartSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user            User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestSession    GuestSession?    @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  store           Store?           @relation(fields: [storeId], references: [id])
  items           ReceiptItem[]
  paymentAttempts PaymentAttempt[]

  @@index([sessionId])
  @@index([userId])
  @@index([guestSessionId])
  @@index([storeId])
  @@map("receipts")
}

enum ReceiptStatus {
  DRAFT
  LOCKED
  PAID
  CANCELLED
}

enum PaymentMethod {
  CARD
  CASH
  MOBILE
  WALLET
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

model PaymentAttempt {
  id                    String               @id @default(cuid())
  receiptId             String
  sessionId             String
  userId                String?
  guestSessionId        String?
  provider              String               @default("PAYMOB")
  merchantOrderId       String               @unique
  providerOrderId       String?              @unique
  providerTransactionId String?              @unique
  amountCents           Int
  currency              String               @default("EGP")
  checkoutUrl           String?
  paymentTokenHash      String?
  expiresAt             DateTime?
  status                PaymentAttemptStatus @default(PENDING)
  lastError             String?
  rawResponse           Json?
  rawWebhook            Json?
  metadata              Json?
  completedAt           DateTime?
  failedAt              DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
  @@index([sessionId])
  @@index([userId])
  @@index([guestSessionId])
  @@index([status])
  @@map("payment_attempts")
}

enum PaymentAttemptStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

// ─── RECEIPT ITEM ──────────────────────────────────────────────────────────────

model ReceiptItem {
  id        String   @id @default(cuid())
  name      String
  quantity  Int      @default(1)
  price     Float
  category  String?
  receiptId String
  scannedAt DateTime @default(now())

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
  @@map("receipt_items")
}

// ─── PRODUCT CATALOG ───────────────────────────────────────────────────────────

model Product {
  id         String   @id @default(cuid())
  name       String   @unique
  category   String   @default("Other")
  emoji      String?
  price      Float    @default(0)
  popularity Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  favoritedBy   UserFavoriteProduct[]
  wishlistItems WishlistItem[]

  @@map("products")
}

// ─── USER STATS (Analytics) ────────────────────────────────────────────────────

model UserStats {
  id                 String @id @default(cuid())
  userId             String @unique
  totalOrders        Int    @default(0)
  totalSpent         Float  @default(0)
  averageBasketValue Float  @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

// ─── USER FAVORITE PRODUCTS ────────────────────────────────────────────────────

model UserFavoriteProduct {
  id            String   @id @default(cuid())
  userId        String
  productId     String
  purchaseCount Int      @default(1)
  lastPurchased DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("user_favorite_products")
}

// ─── WISHLIST ──────────────────────────────────────────────────────────────────

model Wishlist {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WishlistItem[]

  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  addedAt    DateTime @default(now())
  note       String?

  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
  @@index([wishlistId])
  @@map("wishlist_items")
}

// ─── NOTIFICATIONS ─────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

enum NotificationType {
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  RECEIPT_READY
  SESSION_STARTED
  SESSION_ENDED
  WISHLIST_PRICE_DROP
  SYSTEM
}
