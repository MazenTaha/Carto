{
  "name": "carto",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev -H 0.0.0.0 -p 3000",
    "dev:host": "next dev -H 0.0.0.0",
    "dev:https": "next dev --experimental-https -H 0.0.0.0",
    "open:local": "start \"\" http://localhost:3000",
    "tunnel": "npx ngrok http 3000",
    "tunnel:ngrok": "npx ngrok http 3000",
    "tunnel:cloudflare": "cloudflared tunnel --url http://localhost:3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:seed:admins": "ts-node --esm prisma/seed-admins.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.19.0",
    "@stripe/stripe-js": "^2.4.0",
    "@tailwindcss/forms": "^0.5.11",
    "@zxing/browser": "^0.1.5",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^17.2.3",
    "firebase": "^10.14.1",
    "firebase-admin": "^12.4.0",
    "lucide-react": "^1.16.0",
    "next": "^14.2.0",
    "next-auth": "^4.24.7",
    "next-pwa": "^5.6.0",
    "qrcode": "^1.5.3",
    "qrcode.react": "^3.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-qr-code": "^2.0.21",
    "recharts": "^3.8.1",
    "stripe": "^14.21.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.38",
    "prisma": "^5.19.0",
    "tailwindcss": "^3.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
