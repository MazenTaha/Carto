# Database
DATABASE_URL="postgresql://user:password@localhost:5432/carto?schema=public"

# Auth.js / NextAuth
# Set either AUTH_SECRET or NEXTAUTH_SECRET. AUTH_SECRET is preferred.
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_SECRET=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional admin allowlist for admin dashboard and admin APIs
ADMIN_EMAILS="admin@gmail.com"

# Protected demo cart provisioning
DEMO_SETUP_TOKEN=""
DEMO_DEVICE_SECRET="dev-device-secret"

# Firebase client SDK (browser phone OTP)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Firebase Admin SDK (server-side phone token verification only)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Paymob / Unified Checkout
PAYMOB_API_KEY=""
PAYMOB_PUBLIC_KEY=""
PAYMOB_SECRET_KEY=""
PAYMOB_HMAC_SECRET=""
PAYMOB_INTEGRATION_ID=""
PAYMOB_API_BASE_URL="https://accept.paymob.com"
PAYMOB_HOSTED_BASE_URL="https://accept.paymob.com"

# Demo / test payment fallback
PAYMENT_ALLOW_ZERO_TOTAL_FALLBACK="true"
PAYMENT_MIN_TEST_AMOUNT_EGP="1"

# App URLs
APP_URL="https://cartovercel1.vercel.app"
NEXTAUTH_URL="https://cartovercel1.vercel.app"

# Optional legacy iframe checkout only if still used
PAYMOB_IFRAME_ID=""
