# Database
DATABASE_URL="postgresql://user:password@localhost:5432/carto?schema=public"

# Auth.js / NextAuth
# Set either AUTH_SECRET or NEXTAUTH_SECRET. AUTH_SECRET is preferred.
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional admin allowlist for admin dashboard and admin APIs
ADMIN_EMAILS="admin@gmail.com"

# Firebase client SDK (browser phone OTP)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Firebase Admin SDK (server-side phone token verification only)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional payment keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
